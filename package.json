{
  "name": "my-password",
  "version": "mvp",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:run": "vitest run",
    "db:pull": "prisma db pull",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "lint": "pnpm lint:tsc && pnpm lint:eslint && pnpm lint:prettier && prisma format",
    "lint:tsc": "tsc --noEmit",
    "lint:eslint": "eslint --fix",
    "lint:prettier": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md,mdx}\"",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "jose": "^6.2.2",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "better-sqlite3",
      "argon2"
    ]
  }
}
